{
  "name": "devstart-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": ["cli", "web"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "lint": "oxlint --ignore-path .gitignore .",
    "typecheck": "tsc --noEmit -p cli/tsconfig.json",
    "test": "bun test",
    "dev:web": "bun run --filter web dev",
    "build:web": "bun run --filter web build",
    "lint:web": "bun run --filter web lint",
    "typecheck:web": "bun run --filter web typecheck",
    "start:web": "bun run --filter web start",
    "verify:nextjs-base": "bash scripts/verify-nextjs-base.sh",
    "verify:nextjs-dev-tooling": "bash scripts/verify-nextjs-dev-tooling.sh",
    "verify:nextjs-dev-tooling-github-workflows": "bash scripts/verify-nextjs-dev-tooling-github-workflows.sh",
    "verify:nextjs-ds-workflow-dev-tooling": "bash scripts/verify-nextjs-ds-workflow-dev-tooling.sh",
    "verify:nextjs-better-auth-prisma": "bash scripts/verify-nextjs-better-auth-prisma.sh",
    "verify:nextjs-better-auth-prisma-github-workflows": "bash scripts/verify-nextjs-better-auth-prisma-github-workflows.sh",
    "verify:nextjs-better-auth-prisma-dev-tooling": "bash scripts/verify-nextjs-better-auth-prisma-dev-tooling.sh",
    "verify:nextjs-github-workflows": "bash scripts/verify-nextjs-github-workflows.sh",
    "verify:nextjs-prisma": "bash scripts/verify-nextjs-prisma.sh",
    "verify:nextjs-prisma-github-workflows": "bash scripts/verify-nextjs-prisma-github-workflows.sh",
    "verify:nextjs-prisma-dev-tooling": "bash scripts/verify-nextjs-prisma-dev-tooling.sh",
    "verify:nextjs-ds-workflow": "bash scripts/verify-nextjs-ds-workflow.sh",
    "verify:nextjs-ds-workflow-github-workflows": "bash scripts/verify-nextjs-ds-workflow-github-workflows.sh",
    "verify:nextjs-prisma-ds-workflow": "bash scripts/verify-nextjs-prisma-ds-workflow.sh",
    "verify:nextjs-prisma-ds-workflow-dev-tooling": "bash scripts/verify-nextjs-prisma-ds-workflow-dev-tooling.sh",
    "verify:nextjs-stripe-better-auth": "bash scripts/verify-nextjs-stripe-better-auth.sh",
    "verify:nextjs-stripe-clerk": "bash scripts/verify-nextjs-stripe-clerk.sh",
    "pack:cli-local": "bash scripts/pack-cli-local.sh",
    "pack:cli-dry-run": "cd cli && ASDF_NODEJS_CANON_NPM_PATH=$(asdf where nodejs)/bin/npm npm pack --dry-run",
    "prepare": "husky",
    "precommit": "lint-staged --config package.json"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "oxlint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^25.1.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3"
  }
}

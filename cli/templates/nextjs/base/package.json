{
  "name": "devstart-template",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "env:check": "varlock load",
    "env:scan": "varlock scan",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'tsgo --noEmit'",
      "bash -c 'bun run test'"
    ]
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "@varlock/nextjs-integration": "^0.3.4",
    "next": "16.1.7",
    "next-ts-api": "^1.1.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "varlock": "^0.9.1"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript/native-preview": "^7.0.0-dev.20260416",
    "@vitejs/plugin-react": "^4.5.2",
    "chokidar": "^5.0.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.11.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@next/env": "npm:@varlock/nextjs-integration"
  }
}
